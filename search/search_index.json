0c\u7cfb\u7edf\u4f1a\u89c6\u4e3a\u4e00\u4e2a\u65b0\u73a9\u5bb6\uff0c\u5bfc\u81f4\u65e0\u6cd5\u8bfb\u53d6\u65e7\u6570\u636e\u3002 \u5f3a\u70c8\u5efa\u8bae\u4e0d\u8981\u968f\u610f\u66f4\u6539\u60a8\u7684\u6e38\u620fID\u3002\u5982\u679c\u5df2\u66f4\u6539\u5e76\u4e22\u5931\u6570\u636e\uff0c\u8bf7\u8054\u7cfb\u670d\u4e3b\u67e5\u770b\u662f\u5426\u6709\u6062\u590d\u7684\u53ef\u80fd\u3002</p>"},{"location":"guides/FAQs/#2","title":"2. \u8fde\u63a5\u670d\u52a1\u5668\u8d85\u65f6","text":"<p>\u95ee\u9898\u63cf\u8ff0\uff1a\u65e0\u6cd5\u8fde\u63a5\u670d\u52a1\u5668\uff0c\u63d0\u793a\u201c\u8fde\u63a5\u8d85\u65f6\u201d\u6216\u201c\u65e0\u6cd5\u8fde\u63a5\u201d\u3002</p> <p>\u53ef\u80fd\u539f\u56e0\u53ca\u6392\u67e5\u6b65\u9aa4\uff1a 1. \u670d\u52a1\u5668\u72b6\u6001\uff1a\u670d\u4e3b\u53ef\u80fd\u6b63\u5728\u7ef4\u62a4\u6216\u91cd\u542f\u670d\u52a1\u5668\uff0c\u8bf7\u7a0d\u540e\u518d\u8bd5\u6216\u5173\u6ce8\u7fa4\u516c\u544a\u3002 2. \u8fde\u63a5\u4fe1\u606f\uff1a\u8bf7\u4ed4\u7ec6\u68c0\u67e5\u60a8\u8f93\u5165\u7684\u670d\u52a1\u5668IP\u5730\u5740\u548c\u7aef\u53e3\u53f7\u662f\u5426\u6b63\u786e\u3002 3. \u7f51\u7edc\u95ee\u9898\uff1a\u68c0\u67e5\u60a8\u7684\u672c\u5730\u7f51\u7edc\u8fde\u63a5\u662f\u5426\u6b63\u5e38\u3002</p>"},{"location":"guides/FAQs/#_3","title":"\u2753 \u5982\u4f55\u6709\u6548\u63d0\u95ee","text":"<p>\u5982\u679c\u4ee5\u4e0a\u65b9\u6cd5\u672a\u80fd\u89e3\u51b3\u60a8\u7684\u95ee\u9898\uff0c\u53ef\u4ee5\u5411\u7ba1\u7406\u5458\u63d0\u95ee\u3002\u4e3a\u4e86\u63d0\u9ad8\u6c9f\u901a\u6548\u7387\uff0c\u8bf7\u9075\u5faa\u4ee5\u4e0b\u63d0\u95ee\u89c4\u8303\uff1a</p> <ol> <li>\u63d0\u95ee\u524d\u5148\u81ea\u67e5\uff1a\u786e\u4fdd\u60a8\u63cf\u8ff0\u7684\u95ee\u9898\u6e05\u6670\u3001\u7b26\u5408\u5e38\u7406\uff0c\u5e76\u5df2\u81ea\u884c\u5c1d\u8bd5\u8fc7\u57fa\u7840\u6392\u67e5\uff08\u5982\u91cd\u542f\u6e38\u620f\u3001\u68c0\u67e5\u7f51\u7edc\u7b49\uff09\u3002</li> <li>\u63cf\u8ff0\u5177\u4f53\u660e\u786e\uff1a</li> <li>\u907f\u514d\u4f7f\u7528\u81ea\u521b\u7684\u6a21\u7cca\u8bcd\u6c47\u6216\u53e3\u8bed\u5316\u3001\u60c5\u7eea\u5316\u7684\u8868\u8fbe\u3002</li> <li>\u6e05\u6670\u8bf4\u660e\u95ee\u9898\u73b0\u8c61\u3001\u53d1\u751f\u65f6\u95f4\u3001\u60a8\u7684\u64cd\u4f5c\u6b65\u9aa4\u4ee5\u53ca\u4efb\u4f55\u76f8\u5173\u7684\u9519\u8bef\u63d0\u793a\u3002</li> <li>\u5584\u7528\u641c\u7d22\u5de5\u5177\uff1a</li> <li>\u63d0\u95ee\u524d\uff0c\u5efa\u8bae\u5148\u5229\u7528\u641c\u7d22\u5f15\u64ce\uff08\u5982 Bing.com\uff09\u6216AI\u5de5\u5177\uff08\u5982 DeepSeek\uff09\u81ea\u884c\u5bfb\u627e\u89e3\u51b3\u65b9\u6848\u3002</li> <li>\u8fd9\u4e0d\u4ec5\u80fd\u66f4\u5feb\u89e3\u51b3\u95ee\u9898\uff0c\u4e5f\u662f\u4e00\u79cd\u826f\u597d\u7684\u5b66\u4e60\u4e60\u60ef\u3002</li> <li>\u6587\u660e\u6c9f\u901a\uff1a</li> <li>\u8bf7\u52ff\u5728\u7fa4\u5185\u81ea\u8a00\u81ea\u8bed\u3001\u5237\u5c4f\u6216\u53d1\u8868\u4efb\u4f55\u8fb1\u9a82\u6027\u8a00\u8bba\u3002</li> <li>\u5c0a\u91cd\u4ed6\u4eba\uff0c\u5c06\u793e\u7fa4\u548c\u4ed6\u4eba\u89c6\u4e3a\u5171\u540c\u8ba8\u8bba\u7684\u4f19\u4f34\uff0c\u800c\u975e\u5355\u7eaf\u7684\u201c\u641c\u7d22\u5f15\u64ce\u201d\u3002</li> </ol> <p>\u63d0\u95ee\u683c\u5f0f\u4f8b\u5982\uff1a \u95ee\u9898\u7c7b\u578b\uff1a\u8fde\u63a5\u95ee\u9898 \u53d1\u751f\u65f6\u95f4\uff1a\u4eca\u5929\u4e0b\u53483\u70b9 \u6211\u7684\u64cd\u4f5c\uff1a\u5c1d\u8bd5\u7528\u5730\u5740: <code>shamizo.top</code> \u8fde\u63a5 \u9519\u8bef\u63d0\u793a\uff1a\u663e\u793a<code>Connection timed out</code> \u6211\u5df2\u5c1d\u8bd5\uff1a\u786e\u8ba4\u5730\u5740\u65e0\u8bef\uff0c\u5e76\u91cd\u542f\u4e86\u6e38\u620f\u548c\u8def\u7531\u5668\uff0c\u95ee\u9898\u4f9d\u65e7\u3002</p>"},{"location":"guides/join1/","title":"\u6b63\u5f0f\u8fdb\u670d","text":""},{"location":"guides/join1/#_1","title":"\u6b63\u5f0f\u8fdb\u670d","text":"<p>Tip</p> <p>\u670d\u52a1\u5668\u5730\u5740: shamizo.top</p> <p>\u4f7f\u7528 1.21.8 \u8fdb\u5165\u6e38\u620f\u540e\uff0c\u70b9\u51fb\u300c\u591a\u4eba\u6e38\u620f\u300d\u2192 \u6dfb\u52a0\u670d\u52a1\u5668 \u2192 \u8f93\u5165 <code>shamizo.top</code> \u2192 \u9009\u62e9\u670d\u52a1\u5668 \u2192 \u52a0\u5165\u670d\u52a1\u5668 \u2192 \u540c\u610f\u5b89\u88c5\u8d44\u6e90\u5305 \u2192 \u8fdb\u884c\u767b\u5f55</p>"},{"location":"guides/join1/#_2","title":"\u5916\u7f6e\u767b\u5f55","text":"<p>\u8bf7\u5148\u524d\u5f80\u76ae\u80a4\u7ad9\u5b8c\u6210\u8d26\u53f7\u6ce8\u518c\u4e0e\u767b\u5f55\u7ed1\u5b9a\uff1a</p> <p>\u70b9\u51fb\u8df3\u8f6c\u81f3\u76ae\u80a4\u7ad9</p>"},{"location":"guides/join2/","title":"\u57fa\u672c\u529f\u80fd","text":""},{"location":"guides/join2/#_1","title":"\u57fa\u672c\u529f\u80fd","text":"<p>\u4e3b\u83dc\u5355</p> <p></p>"},{"location":"guides/join2/#_2","title":"\u5feb\u6377\u5de5\u4f5c\u53f0/\u672b\u5f71\u7bb1/\u6f5c\u5f71\u7bb1","text":"<p> - \u672b\u5f71\u7bb1\u548c\u5de5\u4f5c\u53f0\uff1a\u70b9\u51fb\u5373\u53ef\u6253\u5f00 - \u6f5c\u5f71\u76d2\uff1a\u9700\u8981\u624b\u6301\u6f5c\u5f71\u76d2\u53f3\u952e\u6253\u5f00</p>"},{"location":"guides/join2/#_3","title":"\u77ff\u77f3\u8fde\u9501/\u6811\u6728\u8fde\u9501","text":"<p> \u6253\u5f00\u5f00\u5173\u540e\uff0c\u624b\u6301\u7a3f\u5b50\u6316\u77ff\u6216\u624b\u6301\u65a7\u5b50\u780d\u6811\u5373\u53ef\u89e6\u53d1\u8fde\u9501\u529f\u80fd</p>"},{"location":"guides/join2/#_4","title":"\u4f20\u9001/\u5bb6","text":"<p> - \u8bbe\u7f6e\u5bb6\uff1a\u804a\u5929\u6846\u8f93\u5165 <code>/sethome \u5bb6\u7684\u540d\u5b57</code>   \u4f8b\u5982\uff1a<code>/sethome \u5237\u94c1\u673a</code> - \u56de\u5bb6\uff1a\u70b9\u51fb\u83dc\u5355\u91cc\u7684\u6211\u7684\u5bb6</p> <p> - \u5411\u73a9\u5bb6\u53d1\u8d77\u4f20\u9001\u7533\u8bf7\uff1a<code>/tpa \u73a9\u5bb6\u540d</code>   \u4f8b\u5982\uff1a<code>/tpa Shamizo</code> - \u9080\u8bf7\u73a9\u5bb6\u4f20\u9001\u5230\u4f60\u8fd9\u91cc\uff1a<code>/tpahere</code> - \u8fd4\u56de\u6b7b\u4ea1\u5730\u70b9\uff1a<code>/back</code></p>"},{"location":"guides/join2/#_5","title":"\u9886\u5730","text":"<p>\u70b9\u51fb\u4e0b\u65b9\u6309\u94ae\uff0c\u67e5\u770b\u9886\u5730\u8be6\u7ec6\u4f7f\u7528\u6559\u7a0b\uff1a</p> <p>\u67e5\u770b\u9886\u5730\u64cd\u4f5c\u6587\u6863</p> <p>\uff08\u6ce8\uff1a\u70b9\u51fb\u540e\u5c06\u5728\u65b0\u7a97\u53e3\u6253\u5f00\u6559\u7a0b\u9875\u9762\uff0c\u5efa\u8bae\u4f7f\u7528\u6d4f\u89c8\u5668\u8bbf\u95ee\u4ee5\u83b7\u5f97\u6700\u4f73\u4f53\u9a8c\uff09</p>"},{"location":"guides/join2/#_6","title":"\u516c\u4f1a\u7cfb\u7edf","text":"<p> \u6559\u7a0b\u5982\u56fe\u6240\u793a</p>"},{"location":"guides/join2/#_7","title":"\u79f0\u53f7\u7cfb\u7edf","text":"<p> - \u6240\u6709\u79f0\u53f7\u514d\u8d39\uff0c\u652f\u6301\u81ea\u5b9a\u4e49</p>"},{"location":"guides/join2/#_8","title":"\u8d5a\u53d6\u91d1\u5e01","text":""},{"location":"guides/join2/#1","title":"1. \u7b7e\u5230\u5956\u52b1","text":"<p> - \u6bcf\u5929\u81ea\u52a8\u53d1\u653e500\u91d1\u5e01 \ud83d\ude0b</p>"},{"location":"guides/join2/#2","title":"2. \u5176\u4ed6\u83b7\u53d6\u65b9\u5f0f","text":"<p>  \u4ee5\u4e0a\u65b9\u5f0f\u5747\u53ef\u8d5a\u53d6\u91d1\u5e01\uff0c\u5177\u4f53\u6559\u7a0b\u5728\u83dc\u5355\u5185\u67e5\u770b</p> <p>\u5982\u4f55\u5728\u6e38\u620f\u91cc\u542c\u7f51\u6613\u4e91\uff1f</p> <p>\u70b9\u51fb\u4e0b\u65b9\u6309\u94ae\uff0c\u4e0b\u8f7d\u5ba2\u6237\u7aefMod\uff1a</p> <p>\u4e0b\u8f7d\u542c\u6b4cMod</p> <p>\uff08\u6ce8\uff1a\u6682\u672a\u627e\u52301.21.8\u7248\u672c\uff0c\u53ef\u4f7f\u75281.21.6\u7248\u672c\u66ff\u4ee3\uff09 </p>"},{"location":"guides/join2/#_9","title":"\u8d85\u8fdc\u89c6\u8ddd","text":""},{"location":"guides/join2/#_10","title":"\u6ce8\u610f","text":"<p>\u8d85\u8fdc\u89c6\u8ddd\u529f\u80fd\u9700\u5b89\u88c5\u914d\u5957\u5ba2\u6237\u7aefMod\uff0c\u70b9\u51fb\u4e0b\u65b9\u6309\u94ae\u4e0b\u8f7d\uff1a</p> <p>\u4e0b\u8f7d\u8d85\u8fdc\u89c6\u8dddMod</p> <p>\uff08\u6ce8\uff1a\u5df2\u9002\u914d1.21.8\u7248\u672c\uff0c\u63a8\u8350\u5ba2\u6237\u7aef\u7248\u672c\u4f7f\u7528\uff09</p>"},{"location":"guides/join2/#_11","title":"\u6a21\u7ec4\u7b80\u4ecb","text":"<p>\u57fa\u4e8e Level of Detail (LOD) \u6280\u672f\u7684\u6027\u80fd\u4f18\u5316\u6a21\u7ec4\uff0c\u901a\u8fc7\u4ee5\u4e0b\u65b9\u5f0f\u63d0\u5347\u6e38\u620f\u4f53\u9a8c\uff1a - \u52a8\u6001\u7b80\u5316\u5730\u5f62\uff1a\u8fdc\u5904\u65b9\u5757\u81ea\u52a8\u5408\u5e76\u4e3a\u4f4e\u6a21\u6a21\u578b\uff0c\u663e\u8457\u964d\u4f4eGPU\u8d1f\u8f7d - \u8d85\u8fdc\u89c6\u8ddd\uff1a\u7a81\u7834\u539f\u7248\u89c6\u8ddd\u9650\u5236\uff0c\u8f7b\u677e\u773a\u671b\u6570\u4e07\u683c\u5916\u7684\u5c71\u8109\u4e0e\u5efa\u7b51 - \u5e27\u7387\u4f18\u5316\uff1a\u5373\u4f7f\u5728\u5927\u578b\u4e16\u754c\u4e2d\uff0c\u4e5f\u80fd\u4fdd\u6301\u7a33\u5b9aFPS</p>"},{"location":"guides/join2/#_12","title":"\u529f\u80fd\u6f14\u793a\u56fe","text":""},{"location":"guides/join2/#_13","title":"\u670d\u52a1\u5668\u652f\u6301\u8bf4\u660e","text":"<ul> <li>\u5df2\u9002\u914d\u7248\u672c\uff1a1.21.8\uff08\u63a8\u8350\u5ba2\u6237\u7aef\u7248\u672c\uff09</li> <li>\u81ea\u52a8\u540c\u6b65\u5730\u5f62\u6570\u636e\uff0c\u65e0\u9700\u989d\u5916\u914d\u7f6e\u6587\u4ef6</li> <li>\u7981\u7528\u51b2\u7a81\u6a21\u7ec4\u4ee5\u786e\u4fdd\u517c\u5bb9\u6027</li> </ul>"},{"location":"guides/join2/#_14","title":"\u73a9\u5bb6\u4f7f\u7528\u6307\u5357","text":"<ol> <li>\u8fdb\u5165\u670d\u52a1\u5668\u5373\u751f\u6548</li> <li>\u53ea\u9700\u52a0\u5165\u670d\u52a1\u5668\uff0c\u6a21\u7ec4\u529f\u80fd\u5c06\u81ea\u52a8\u6fc0\u6d3b\uff0c\u65e0\u9700\u989d\u5916\u64cd\u4f5c</li> <li>\u9996\u6b21\u52a0\u8f7d\u65f6\u53ef\u80fd\u77ed\u6682\u5361\u987f\uff0c\u968f\u540e\u8fdb\u5165\u6d41\u7545\u6a21\u5f0f</li> <li>\u8c03\u6574\u89c6\u8ddd\u8bbe\u7f6e\uff08\u63a8\u8350\uff09</li> <li>Render Distance Multiplier: 2x-4x\uff08\u6839\u636e\u786c\u4ef6\u8c03\u6574\uff09</li> <li>LOD Quality: Medium/High\uff08\u5e73\u8861\u753b\u8d28\u4e0e\u6027\u80fd\uff09</li> <li>Disable for Nether: \u5f00\u542f\uff08\u4e0b\u754c\u5173\u95edLOD\u907f\u514d\u5f02\u5e38\uff09</li> <li>\u7279\u8272\u529f\u80fd\u6f14\u793a</li> <li>\u5730\u5f62\u6e10\u53d8\uff1a\u5411\u524d\u5954\u8dd1\u65f6\uff0c\u8fdc\u5904\u65b9\u5757\u4f1a\u5982\u50cf\u7d20\u6eb6\u89e3\u822c\u9010\u6e10\u52a0\u8f7d</li> </ol>"},{"location":"guides/join2/#_15","title":"\u6ce8\u610f\u4e8b\u9879","text":"<ul> <li>\u6750\u8d28\u5305\u517c\u5bb9\u6027\uff1a\u90e8\u5206\u9ad8\u6e05\u6750\u8d28\uff08\u5982Sphax\uff09\u53ef\u80fd\u4e0eLOD\u51b2\u7a81\uff0c\u5efa\u8bae\u4f7f\u7528\u9ed8\u8ba4\u6750\u8d28\u6216\u9002\u914d\u7248</li> <li>\u5df2\u77e5\u95ee\u9898\uff1a\u4e0b\u754c\u706b\u7130/\u70df\u96fe\u53ef\u80fd\u65e0\u6cd5\u6b63\u786eLOD\u5316\uff0c\u5efa\u8bae\u5728\u4e0b\u754c\u4e2d\u5173\u95ed\u9065\u8fdc\u7684\u5730\u5e73\u7ebf</li> </ul>"},{"location":"guides/join2/#_16","title":"\u5e38\u89c1\u95ee\u9898\u89e3\u7b54","text":"<ul> <li>Q1: \u52a0\u5165\u670d\u52a1\u5668\u540e\u6a21\u7ec4\u672a\u751f\u6548\uff1f   A: \u5c1d\u8bd5\u91cd\u65b0\u8fde\u63a5</li> <li>Q2: \u8fdc\u666f\u65b9\u5757\u95ea\u70c1/\u9ed1\u5c4f\uff1f   A: \u66f4\u65b0\u663e\u5361\u9a71\u52a8\uff0c\u5e76\u5728\u6a21\u7ec4\u8bbe\u7f6e\u4e2d\u5173\u95ed \"Dynamic Lighting\" \u9009\u9879</li> </ul>"},{"location":"guides/join2/#_17","title":"\u9632\u76d7","text":"<p> - \u64cd\u4f5c\u8bb0\u5f55\uff1a\u70b9\u51fb\u671b\u8fdc\u955c/\u95e8\u7b49\u65b9\u5757\uff0c\u53ef\u67e5\u770b\u201cxx\u5728xx\u65f6\u95f4\u62ff\u8d70\u4e86xx\u201d\u7684\u8bb0\u5f55 - \u4e0a\u9501\u65b9\u5f0f\uff1a\u624b\u6301\u544a\u793a\u724c\u70b9\u51fb\u95e8\u6216\u7bb1\u5b50\u5373\u53ef\u4e0a\u9501</p>"},{"location":"guides/join2/#_18","title":"\u544a\u793a\u724c\u7269\u54c1\u5c55\u793a","text":""},{"location":"guides/join2/#_19","title":"\u5c55\u793a\u6548\u679c","text":""},{"location":"guides/join2/#_20","title":"\u4f7f\u7528\u65b9\u6cd5","text":"<ol> <li>\u63d2\u5165\u7269\u54c1\uff1a\u53f3\u952e\u544a\u793a\u724c\uff0c\u5c06\u7269\u54c1\u63d2\u5165</li> <li>\u53d6\u51fa\u7269\u54c1\uff1a\u5de6\u952e\u70b9\u51fb\u544a\u793a\u724c\uff0c\u53d6\u51fa\u7269\u54c1</li> <li>\u4e0a\u8721/\u89e3\u8721\uff1a</li> <li>\u4e0a\u8721\uff1a\u7528\u871c\u813e\u70b9\u51fb\u544a\u793a\u724c\uff0c\u7269\u54c1\u5c06\u65e0\u6cd5\u53d6\u8d70</li> <li>\u89e3\u8721\uff1a\u7528\u65a7\u5934\u70b9\u51fb\u544a\u793a\u724c\uff0c\u53ef\u79fb\u9664\u4e0a\u8721\u72b6\u6001</li> </ol>"},{"location":"guides/join2/#_21","title":"\u76f8\u5173\u547d\u4ee4","text":"<p>```bash /ins help  # \u663e\u793a\u547d\u4ee4\u76f8\u5173\u4fe1\u606f /ins clear [\u534a\u5f84]  # \u6e05\u9664\u6307\u5b9a\u534a\u5f84\u8303\u56f4\u5185\u544a\u793a\u724c\u4e0a\u7684\u7269\u54c1</p>"},{"location":"guides/preparation/","title":"\u51c6\u5907\u5de5\u4f5c","text":""},{"location":"guides/preparation/#_1","title":"\u6e38\u620f\u5b89\u88c5\u6307\u5357","text":"<p>Tip</p> <p>\u6211\u4eec\u4e0d\u652f\u6301\u624b\u673a\u7248\u542f\u52a8\u5668\u6e38\u73a9</p>"},{"location":"guides/preparation/#_2","title":"\u6309\u7cfb\u7edf\u9009\u62e9\u542f\u52a8\u5668","text":""},{"location":"guides/preparation/#windows","title":"Windows \u7cfb\u7edf","text":"<p>\u89c6\u9891\u4f5c\u8005\uff1a\u8709\u8763QvQ</p> <ul> <li>PCL\u793e\u533a\u7248\uff1a\u4e0b\u8f7d\u94fe\u63a5</li> <li>PCL2\uff1a\u4e0b\u8f7d\u94fe\u63a5</li> <li>HMCL\uff1a\u4e0b\u8f7d\u94fe\u63a5</li> </ul>"},{"location":"guides/preparation/#mac","title":"Mac \u7cfb\u7edf","text":"<p>\u89c6\u9891\u4f5c\u8005\uff1aDimension_DIM</p> <ul> <li>HMCL\uff1a\u4e0b\u8f7d\u94fe\u63a5</li> </ul>"},{"location":"guides/preparation/#linux","title":"Linux \u7cfb\u7edf","text":"<p>\u89c6\u9891\u4f5c\u8005\uff1a\u559c\u6b22\u8d85\u65b0\u661f\u306e\u7535\u5b50\u72d7</p> <ul> <li>HMCL\uff1a\u4e0b\u8f7d\u94fe\u63a5</li> </ul>"}]}